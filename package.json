{
  "name": "null-graph",
  "version": "0.0.2",
  "description": "A direct-to-GPU rendering framework for massive web worlds. Zero scene graph. Zero copy. Infinite scale.",
  "type": "module",
  "author": "Vikas Kumar Singh",
  "license": "ISC",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist dist-web-test",
    "build:lib": "node build.js && tsc",
    "yalc:push": "npm run build:lib:prod && yalc push",
    "build:lib:prod": "node build.js --production && tsc",
    "bundle:test-ui": "node -e \"if (!require('fs').existsSync('dist-web-test')) require('fs').mkdirSync('dist-web-test', {recursive: true})\" && esbuild test/javascript/index.js --bundle --outfile=dist-web-test/index.js --platform=browser --format=esm --sourcemap",
    "postbuild:test": "node copy-assets.js",
    "build:test": "npm run clean && npm run build:lib:prod && npm run bundle:test-ui && npm run postbuild:test",
    "dev:serve": "node dev-server.js",
    "dev:serve:nosab": "node dev-server.js --no-sab",
    "watch:lib": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=browser --format=esm --sourcemap --watch",
    "watch:test-ui": "esbuild test/javascript/index.js --bundle --outfile=dist-web-test/index.js --platform=browser --format=esm --sourcemap --watch",

    "dev": "concurrently \"npm run watch:lib\" \"npm run watch:test-ui\" \"npm run dev:serve\"",
    "preview": "npx serve dist-web-test"
  },
  "dependencies": {
    "gl-matrix": "^3.4.4"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "rimraf": "^6.1.3",
    "serve": "^14.2.6",
    "typescript": "^5.9.3"
  }
}
